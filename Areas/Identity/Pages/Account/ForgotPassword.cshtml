@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperare Parolă";
}

<div class="mc-login-outer">
    <div class="mc-login-card">
        <div class="mc-login-logo">
            <div class="mc-logo-mark">🔑</div>
            <h2>Recuperare Parolă</h2>
            <p>Introdu email-ul și îți trimitem un link de resetare</p>
        </div>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Adresă Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="email@clinica.ro" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-primary btn-lg mb-3">Trimite Link Resetare</button>
            <p class="text-center mb-0" style="font-size:0.88rem">
                <a asp-page="./Login" style="color:var(--mc-primary)">← Înapoi la autentificare</a>
            </p>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }

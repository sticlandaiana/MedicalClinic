@page
@model ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Email Trimis";
}

<div class="mc-login-outer">
    <div class="mc-login-card text-center">
        <div class="mc-login-logo">
            <div class="mc-logo-mark">✉️</div>
            <h2>Email Trimis!</h2>
        </div>
        <p class="text-muted mb-4">Dacă adresa introdusă există în sistem, vei primi un email cu instrucțiuni de resetare a parolei în câteva minute.</p>
        <a asp-page="./Login" class="btn btn-primary">Înapoi la Autentificare</a>
    </div>
</div>

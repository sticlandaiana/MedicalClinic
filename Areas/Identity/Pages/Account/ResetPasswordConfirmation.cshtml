@page
@{
    ViewData["Title"] = "Parolă Resetată";
}

<div class="mc-login-outer">
    <div class="mc-login-card text-center">
        <div class="mc-login-logo">
            <div class="mc-logo-mark">✅</div>
            <h2>Parolă Resetată!</h2>
        </div>
        <p class="text-muted mb-4">Parola ta a fost schimbată cu succes. Te poți autentifica acum cu noua parolă.</p>
        <a asp-page="./Login" class="btn btn-primary">Autentificare</a>
    </div>
</div>

@page
@model MedicalClinic.Pages.Admin.EquipmentsModel
@{
    ViewData["Title"] = "Echipamente";
}

<div class="mc-page-header">
    <h2>Echipamente Medicale</h2>
    <a href="/Admin/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

<div class="mc-add-row mb-3">
    <p class="mc-section-title mb-2">Adaugă echipament nou</p>
    <form method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Nume echipament</label>
                <input asp-for="NewEquipmentName" class="form-control" placeholder="ex: Aparat Ecograf 3D" />
                <span asp-validation-for="NewEquipmentName" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label class="form-label">Sală</label>
                <select asp-for="NewEquipmentRoomId" class="form-select"
                        asp-items="@(new SelectList(Model.Rooms, "RoomId", "Name"))">
                    <option value="">— Selectează sala —</option>
                </select>
                <span asp-validation-for="NewEquipmentRoomId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Adaugă</button>
            </div>
        </div>
    </form>
</div>

<div class="mc-add-row mb-4" style="background:#fff">
    <form method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Filtrează status</label>
                <select name="filterStatus" class="form-select">
                    <option value="">— Toate —</option>
                    <option value="Functional" selected="@(Model.FilterStatus == "Functional")">Funcțional</option>
                    <option value="Maintenance" selected="@(Model.FilterStatus == "Maintenance")">Mentenanță</option>
                    <option value="Defect" selected="@(Model.FilterStatus == "Defect")">Defect</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Filtrează sală</label>
                <select name="filterRoomId" class="form-select">
                    <option value="">— Toate sălile —</option>
                    @foreach (var r in Model.Rooms)
                    {
                        <option value="@r.RoomId" selected="@(Model.FilterRoomId == r.RoomId)">@r.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrează</button>
            </div>
            <div class="col-md-2">
                <a href="/Admin/Equipments" class="btn btn-secondary w-100">Resetează</a>
            </div>
        </div>
    </form>
</div>

<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Nume</th>
                <th>Sală</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in Model.Equipments)
            {
                <tr>
                    <td class="fw-medium">@e.Name</td>
                    <td class="text-muted">@e.Room.Name</td>
                    <td>
                        <span class="badge @(e.Status == "Functional" ? "bg-success" : e.Status == "Maintenance" ? "bg-warning" : "bg-danger")">
                            @(e.Status == "Functional" ? "Funcțional" : e.Status == "Maintenance" ? "Mentenanță" : "Defect")
                        </span>
                    </td>
                    <td>
                        <div class="action-group">
                            <form method="post" asp-page-handler="ChangeStatus">
                                <input type="hidden" name="id" value="@e.EquipmentId" />
                                <select name="status" class="form-select form-select-sm d-inline" style="width:auto">
                                    <option value="Functional" selected="@(e.Status == "Functional")">Funcțional</option>
                                    <option value="Maintenance" selected="@(e.Status == "Maintenance")">Mentenanță</option>
                                    <option value="Defect" selected="@(e.Status == "Defect")">Defect</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-warning">Schimbă</button>
                            </form>
                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden" name="id" value="@e.EquipmentId" />
                                <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
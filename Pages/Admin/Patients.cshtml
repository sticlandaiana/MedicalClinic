@page
@model MedicalClinic.Pages.Admin.PatientsModel
@{
    ViewData["Title"] = "Gestionare Pacienți";
}

<div class="mc-page-header">
    <h2>Gestionare Pacienți</h2>
    <a href="/Admin/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-4">@Model.SuccessMessage</div>
}

<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Nume</th>
                <th>Email</th>
                <th>No-Show</th>
                <th>Status</th>
                <th style="width:160px">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Patients)
            {
                <tr>
                    <td class="fw-medium">@p.Name</td>
                    <td class="text-muted">@p.User.Email</td>
                    <td>
                        <span class="@(p.NoShowCount >= 3 ? "text-danger fw-semibold" : "")">@p.NoShowCount</span>
                    </td>
                    <td>
                        <span class="badge @(p.NoShowCount >= 3 ? "bg-danger" : "bg-success")">
                            @(p.NoShowCount >= 3 ? "Suspendat" : "Activ")
                        </span>
                    </td>
                    <td>
                        @if (p.NoShowCount >= 3)
                        {
                            <form method="post" asp-page-handler="ResetNoShow">
                                <input type="hidden" name="patientId" value="@p.PatientId" />
                                <button type="submit" class="btn btn-sm btn-success">Resetează No-Show</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@page
@model MedicalClinic.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard Administrator";
}

<div class="mc-welcome-banner">
    <h1>Bun venit, Administrator!</h1>
    <p>Gestionează resursele, personalul și configurările clinicii.</p>
</div>

<p class="mc-section-title">Gestionare Resurse</p>
<div class="mc-dashboard mb-4">
    <a href="/Admin/Specialities" class="mc-dash-card">
        <span class="mc-dash-icon">🏥</span>
        <span class="mc-dash-label">Specialități</span>
    </a>
    <a href="/Admin/Rooms" class="mc-dash-card">
        <span class="mc-dash-icon">🚪</span>
        <span class="mc-dash-label">Săli Medicale</span>
    </a>
    <a href="/Admin/Equipments" class="mc-dash-card">
        <span class="mc-dash-icon">🔬</span>
        <span class="mc-dash-label">Echipamente</span>
    </a>
    <a href="/Admin/ConsultationTypes" class="mc-dash-card">
        <span class="mc-dash-icon">📝</span>
        <span class="mc-dash-label">Tipuri Consultație</span>
    </a>
</div>

<p class="mc-section-title">Gestionare Personal & Pacienți</p>
<div class="mc-dashboard mb-4">
    <a href="/Admin/Staff" class="mc-dash-card">
        <span class="mc-dash-icon">👩‍⚕️</span>
        <span class="mc-dash-label">Personal</span>
    </a>
    <a href="/Admin/DoctorSpecialities" class="mc-dash-card">
        <span class="mc-dash-icon">🩺</span>
        <span class="mc-dash-label">Specialități Doctori</span>
    </a>
    <a href="/Admin/NurseDoctorAssignments" class="mc-dash-card">
        <span class="mc-dash-icon">🔗</span>
        <span class="mc-dash-label">Dependențe Asistentă–Doctor</span>
    </a>
    <a href="/Admin/Reviews" class="mc-dash-card">
        <span class="mc-dash-icon">💬</span>
        <span class="mc-dash-label">Moderare Recenzii</span>
    </a>
    <a href="/Admin/Patients" class="mc-dash-card">
        <span class="mc-dash-icon">👥</span>
        <span class="mc-dash-label">Pacienți</span>
    </a>
</div>

<p class="mc-section-title">Monitorizare</p>
<div class="mc-dashboard">
    <a href="/Shared/Calendar" class="mc-dash-card">
        <span class="mc-dash-icon">📅</span>
        <span class="mc-dash-label">Calendar Programări</span>
    </a>
    <a href="/Admin/AuditLogs" class="mc-dash-card">
        <span class="mc-dash-icon">📋</span>
        <span class="mc-dash-label">Audit Log</span>
    </a>
</div>

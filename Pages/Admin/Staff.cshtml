@page
@model MedicalClinic.Pages.Admin.StaffModel
@{
    ViewData["Title"] = "Gestionare Personal";
}

<div class="mc-page-header">
    <h2>Gestionare Personal</h2>
    <a href="/Admin/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="mc-add-row mb-4">
    <p class="mc-section-title mb-2">Adaugă membru personal nou</p>
    <form method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Nume complet</label>
                <input asp-for="NewName" class="form-control" placeholder="Prenume Nume" />
                <span asp-validation-for="NewName" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Email</label>
                <input asp-for="NewEmail" class="form-control" placeholder="email@clinica.ro" />
                <span asp-validation-for="NewEmail" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Parolă</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••••" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Rol</label>
                <select asp-for="NewRole" class="form-select">
                    <option value="">— Rol —</option>
                    <option value="Doctor">Doctor</option>
                    <option value="Nurse">Asistentă</option>
                </select>
                <span asp-validation-for="NewRole" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Adaugă</button>
            </div>
        </div>
    </form>
</div>

<p class="mc-section-title">Doctori</p>
<div class="mc-table-wrapper mb-4" style="overflow-x:auto;">
    <table class="table table-striped mb-0" style="min-width:600px;">
        <thead>
            <tr>
                <th>Nume</th>
                <th>Email</th>
                <th>Specialități</th>
                <th style="width:100px">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.Doctors)
            {
                <tr>
                    <td class="fw-medium">@d.Name</td>
                    <td class="text-muted">@d.User.Email</td>
                    <td>
                        @if (d.DoctorSpecialities.Any())
                        {
                            @foreach (var sp in d.DoctorSpecialities)
                            {
                                <span class="badge bg-primary me-1">@sp.Speciality.Name</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted" style="font-size:0.82rem">Neasignat</span>
                        }
                    </td>
                    <td>
                        <form method="post" asp-page-handler="DeleteStaff">
                            <input type="hidden" name="userId" value="@d.UserId" />
                            <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<p class="mc-section-title">Asistente</p>
<div class="mc-table-wrapper" style="overflow-x:auto;">
    <table class="table table-striped mb-0" style="min-width:600px;">
        <thead>
            <tr>
                <th>Nume</th>
                <th>Email</th>
                <th style="width:100px">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.Nurses)
            {
                <tr>
                    <td class="fw-medium">@n.Name</td>
                    <td class="text-muted">@n.User.Email</td>
                    <td>
                        <form method="post" asp-page-handler="DeleteStaff">
                            <input type="hidden" name="userId" value="@n.UserId" />
                            <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
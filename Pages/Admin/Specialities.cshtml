@page
@model MedicalClinic.Pages.Admin.SpecialitiesModel
@{
    ViewData["Title"] = "Specialități";
}

<div class="mc-page-header">
    <h2>Specialități Medicale</h2>
    <a href="/Admin/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

<div class="mc-add-row mb-4">
    <p class="mc-section-title mb-2">Adaugă specialitate nouă</p>
    <form method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Nume specialitate</label>
                <input asp-for="NewSpecialityName" class="form-control" placeholder="ex: Cardiologie" />
                <span asp-validation-for="NewSpecialityName" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Adaugă</button>
            </div>
        </div>
    </form>
</div>

<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Nume Specialitate</th>
                <th style="width:120px">Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Specialities)
            {
                <tr>
                    <td class="fw-medium">@s.Name</td>
                    <td>
                        <form method="post" asp-page-handler="Delete">
                            <input type="hidden" name="id" value="@s.SpecialityId" />
                            <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
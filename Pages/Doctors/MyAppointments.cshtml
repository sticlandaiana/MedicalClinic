@page
@model MedicalClinic.Pages.Doctors.MyAppointmentsModel
@{
    ViewData["Title"] = "Programările Mele";
}

<div class="mc-page-header">
    <h2>Programările Mele</h2>
    <a href="/Doctors/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-4">@Model.SuccessMessage</div>
}

<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Data</th>
                <th>Pacient</th>
                <th>Tip Consultație</th>
                <th>Sală</th>
                <th>Asistentă</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Appointments)
            {
                <tr>
                    <td class="fw-medium">@a.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@a.Patient.Name</td>
                    <td class="text-muted">@a.ConsultationType.Name</td>
                    <td class="text-muted">@a.Room.Name</td>
                    <td class="text-muted">@(a.Nurse?.Name ?? "—")</td>
                    <td>
                        <span class="badge @(a.Status == "Scheduled" ? "bg-primary" : a.Status == "Completed" ? "bg-success" : a.Status == "Cancelled" ? "bg-danger" : "bg-warning")">
                            @(a.Status == "Scheduled" ? "Programat" : a.Status == "Completed" ? "Finalizat" : a.Status == "Cancelled" ? "Anulat" : a.Status)
                        </span>
                    </td>
                    <td>
                        <div class="action-group">
                            @if (a.Status == "Scheduled")
                            {
                                <form method="post" asp-page-handler="Complete">
                                    <input type="hidden" name="id" value="@a.AppointmentId" />
                                    <button type="submit" class="btn btn-sm btn-success">✓ Finalizează</button>
                                </form>
                                <form method="post" asp-page-handler="NoShow">
                                    <input type="hidden" name="id" value="@a.AppointmentId" />
                                    <button type="submit" class="btn btn-sm btn-warning">No Show</button>
                                </form>
                            }
                            @if (a.Status == "Completed")
                            {
                                <a href="/Doctors/AddRecord?appointmentId=@a.AppointmentId" class="btn btn-sm btn-primary">+ Adaugă Fișă</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
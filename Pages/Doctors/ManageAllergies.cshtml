@page
@model MedicalClinic.Pages.Doctors.ManageAllergiesModel
@{
    ViewData["Title"] = "Gestionare Alergii";
}

<div class="mc-page-header">
    <div>
        <h2>Gestionare Alergii</h2>
        <p class="text-muted mb-0" style="font-size:0.88rem">Pacient: <strong>@Model.PatientName</strong></p>
    </div>
    <a href="/Doctors/PatientRecord?patientId=@Model.PatientId" class="btn btn-secondary">Înapoi la Dosar</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-4">@Model.SuccessMessage</div>
}

<div class="mc-add-row mb-4">
    <p class="mc-section-title mb-2">Adaugă alergie nouă</p>
    <form method="post">
        <input type="hidden" name="patientId" value="@Model.PatientId" />
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Descriere alergie</label>
                <input asp-for="Description" class="form-control" placeholder="ex: Penicilină, Polen, Arahide..." />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-md-3 d-flex align-items-end pb-1">
                <div class="form-check">
                    <input asp-for="IsCritical" class="form-check-input" type="checkbox" />
                    <label asp-for="IsCritical" class="form-check-label fw-medium" style="font-size:0.88rem">Marcare ca Critică</label>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-danger w-100">+ Adaugă</button>
            </div>
        </div>
    </form>
</div>

@if (Model.Allergies.Any())
{
    <div class="mc-table-wrapper">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Descriere</th>
                    <th>Severitate</th>
                    <th style="width:100px">Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model.Allergies)
                {
                    <tr>
                        <td class="fw-medium">@a.Description</td>
                        <td>
                            <span class="badge @(a.IsCritical ? "bg-danger" : "bg-warning")">
                                @(a.IsCritical ? "⚠️ Critică" : "Moderată")
                            </span>
                        </td>
                        <td>
                            <form method="post" asp-page-handler="Delete">
                                <input type="hidden" name="allergyId" value="@a.AllergyId" />
                                <input type="hidden" name="patientId" value="@Model.PatientId" />
                                <button type="submit" class="btn btn-sm btn-danger">Șterge</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">Nu există alergii înregistrate pentru acest pacient.</div>
}

@page
@model MedicalClinic.Pages.Doctors.MyProfileModel
@{
    ViewData["Title"] = "Profilul Meu";
}

<div class="mc-page-header">
    <h2>Profilul Meu</h2>
    <a href="/Doctors/Dashboard" class="btn btn-secondary">Înapoi</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body p-4">
                <div style="width:72px;height:72px;background:var(--mc-primary-light);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2.2rem;margin-bottom:1rem;">👨‍⚕️</div>
                <h4 class="mb-1">@Model.DoctorName</h4>
                <p class="text-muted mb-3" style="font-size:0.88rem">@Model.Specialities</p>
                <hr />
                <p class="mc-section-title">Rating Mediu</p>
                <div style="font-size:1.6rem;letter-spacing:0.05em;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span style="color: @(i <= Math.Round(Model.AverageRating) ? "#E8A900" : "#DDE3F0")">★</span>
                    }
                </div>
                <p class="mt-2 mb-0" style="font-size:0.9rem">
                    <strong>@Model.AverageRating.ToString("0.0")</strong>
                    <span class="text-muted">/ 5.0 (@Model.TotalReviews recenzii)</span>
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <p class="mc-section-title">Recenzii Pacienți</p>
        @if (Model.Reviews.Any())
        {
            @foreach (var r in Model.Reviews)
            {
                <div class="card mb-2">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <strong style="font-size:0.9rem">@(r.IsAnonymous ? "Anonim" : r.Patient.Name)</strong>
                            <span class="mc-stars" style="font-size:0.95rem">
                                @string.Concat(Enumerable.Repeat("★", r.Score))@string.Concat(Enumerable.Repeat("☆", 5 - r.Score))
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(r.Comment))
                        {
                            <p class="mt-2 mb-0 text-muted" style="font-size:0.88rem">@r.Comment</p>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">Nu există recenzii aprobate încă.</div>
        }
    </div>
</div>

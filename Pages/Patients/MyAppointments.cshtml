@page
@model MedicalClinic.Pages.Patients.MyAppointmentsModel
@{
    ViewData["Title"] = "Programările Mele";
}

<div class="mc-page-header">
    <h2>Programările Mele</h2>
    <a href="/Patients/BookAppointment" class="btn btn-primary">📅 Programare Nouă</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Data</th>
                <th>Doctor</th>
                <th>Specialitate</th>
                <th>Tip Consultație</th>
                <th>Sală</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Appointments)
            {
                <tr>
                    <td class="fw-medium">@a.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@a.Doctor.Name</td>
                    <td class="text-muted">@a.ConsultationType.Speciality.Name</td>
                    <td class="text-muted">@a.ConsultationType.Name</td>
                    <td class="text-muted">@a.Room.Name</td>
                    <td>
                        <span class="badge @(a.Status == "Scheduled" ? "bg-primary" : a.Status == "Completed" ? "bg-success" : a.Status == "Cancelled" ? "bg-danger" : a.Status == "NeedsRescheduling" ? "bg-warning" : "bg-secondary")">
                            @(a.Status == "Scheduled" ? "Programat" : a.Status == "Completed" ? "Finalizat" : a.Status == "Cancelled" ? "Anulat" : a.Status == "NeedsRescheduling" ? "Reprogramare" : a.Status)
                        </span>
                    </td>
                    <td>
                        @if (a.Status == "Scheduled")
                        {
                            @if ((a.StartTime - DateTime.Now).TotalHours >= 24)
                            {
                                <form method="post" asp-page-handler="Cancel">
                                    <input type="hidden" name="id" value="@a.AppointmentId" />
                                    <button type="submit" class="btn btn-sm btn-danger">Anulează</button>
                                </form>
                            }
                            else
                            {
                                <small class="text-muted">Anulare doar telefonic</small>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@page
@model MedicalClinic.Pages.Nurses.AppointmentsModel
@{
    ViewData["Title"] = "Gestionare Programări";
}

<div class="mc-page-header">
    <h2>Gestionare Programări</h2>
    <a href="/Nurses/Dashboard" class="btn btn-secondary">← Înapoi</a>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success mb-4">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-4">@Model.ErrorMessage</div>
}

<div class="mc-add-row mb-4">
    <p class="mc-section-title mb-2">Programare Nouă pentru Pacient</p>
    <form method="post">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Pacient</label>
                <select asp-for="SelectedPatientId" class="form-select"
                        asp-items="@(new SelectList(Model.Patients, "PatientId", "Name"))">
                    <option value="">— Selectează pacientul —</option>
                </select>
                <span asp-validation-for="SelectedPatientId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Specialitate</label>
                <select asp-for="SelectedSpecialityId" id="specialitySelect" class="form-select">
                    <option value="">— Specialitate —</option>
                    @foreach (var s in Model.Specialities)
                    {
                        <option value="@s.SpecialityId">@s.Name</option>
                    }
                </select>
                <span asp-validation-for="SelectedSpecialityId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Tip Consultație</label>
                <select asp-for="SelectedConsultationTypeId" id="consultationSelect" class="form-select">
                    <option value="">— Tip —</option>
                    @foreach (var ct in Model.ConsultationTypes)
                    {
                        <option value="@ct.ConsultationTypeId" data-speciality="@ct.SpecialityId">@ct.Name</option>
                    }
                </select>
                <span asp-validation-for="SelectedConsultationTypeId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Doctor</label>
                <select asp-for="SelectedDoctorId" id="doctorSelect" class="form-select">
                    <option value="">— Doctor —</option>
                    @foreach (var d in Model.Doctors)
                    {
                        foreach (var ds in d.DoctorSpecialities)
                        {
                            <option value="@d.DoctorId" data-speciality="@ds.SpecialityId">@d.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="SelectedDoctorId" class="text-danger"></span>
            </div>
            <div class="col-md-2">
                <label class="form-label">Data și Ora</label>
                <input asp-for="SelectedDateTime" class="form-control" type="datetime-local" />
                <span asp-validation-for="SelectedDateTime" class="text-danger"></span>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">+ Add</button>
            </div>
        </div>
    </form>
</div>

<p class="mc-section-title">Toate Programările</p>
<div class="mc-table-wrapper">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>Data</th>
                <th>Pacient</th>
                <th>Doctor</th>
                <th>Tip Consultație</th>
                <th>Status</th>
                <th>Acțiuni</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Appointments)
            {
                <tr>
                    <td class="fw-medium">@a.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@a.Patient.Name</td>
                    <td class="text-muted">@a.Doctor.Name</td>
                    <td class="text-muted">@a.ConsultationType.Name</td>
                    <td>
                        <span class="badge @(a.Status == "Scheduled" ? "bg-primary" : a.Status == "Completed" ? "bg-success" : a.Status == "Cancelled" ? "bg-danger" : "bg-warning")">
                            @(a.Status == "Scheduled" ? "Programat" : a.Status == "Completed" ? "Finalizat" : a.Status == "Cancelled" ? "Anulat" : a.Status)
                        </span>
                    </td>
                    <td>
                        @if (a.Status == "Scheduled")
                        {
                            <div class="action-group">
                                <a href="/Nurses/EditAppointment?appointmentId=@a.AppointmentId" class="btn btn-sm btn-warning">Editează</a>
                                <a href="/Nurses/Triage?appointmentId=@a.AppointmentId" class="btn btn-sm btn-outline-info">🩺 Triaj</a>
                                <form method="post" asp-page-handler="Cancel">
                                    <input type="hidden" name="id" value="@a.AppointmentId" />
                                    <button type="submit" class="btn btn-sm btn-danger">Anulează</button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const specialitySelect = document.getElementById('specialitySelect');
        const consultationSelect = document.getElementById('consultationSelect');
        const doctorSelect = document.getElementById('doctorSelect');
        const allConsultations = Array.from(consultationSelect.options).slice(1);
        const allDoctors = Array.from(doctorSelect.options).slice(1);

        specialitySelect.addEventListener('change', function () {
            const id = this.value;
            consultationSelect.innerHTML = '<option value="">— Tip —</option>';
            allConsultations.filter(o => o.dataset.speciality === id).forEach(o => consultationSelect.appendChild(o.cloneNode(true)));
            doctorSelect.innerHTML = '<option value="">— Doctor —</option>';
            allDoctors.filter(o => o.dataset.speciality === id).forEach(o => doctorSelect.appendChild(o.cloneNode(true)));
        });
    </script>
}
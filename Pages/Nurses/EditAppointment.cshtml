@page
@model MedicalClinic.Pages.Nurses.EditAppointmentModel
@{
    ViewData["Title"] = "Editează Programare";
}

<div class="mc-page-header">
    <h2>Editează Programare</h2>
    <a href="/Nurses/Appointments" class="btn btn-secondary">Înapoi</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger mb-4">@Model.ErrorMessage</div>
}

<div class="mc-form-panel">
    <form method="post">
        <input type="hidden" asp-for="AppointmentId" />
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label">Pacient</label>
                <input class="form-control" value="@Model.PatientName" disabled style="background:#F8FAFF" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Doctor</label>
                <input class="form-control" value="@Model.DoctorName" disabled style="background:#F8FAFF" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Dată și Oră Nouă</label>
                <input asp-for="NewDateTime" class="form-control" type="datetime-local" />
                <span asp-validation-for="NewDateTime" class="text-danger"></span>
            </div>
            <div class="col-md-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Salvează</button>
                <a href="/Nurses/Appointments" class="btn btn-secondary">Anulează</a>
            </div>
        </div>
    </form>
</div>
